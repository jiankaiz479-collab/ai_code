# 1. 忽略虛擬環境與環境變數 (最重要)
venv/
env/
.env

# 2. 忽略 Python 編譯檔
__pycache__/
*.pyc

# 3. 忽略本地資料庫
db.sqlite3

# 4. 忽略上傳的圖片 (保留資料夾結構，但忽略裡面的圖)
media/
!media/.gitkeep

# 5. 忽略編輯器設定與暫存檔
.vscode/
.idea/
.DS_Store



# 讓 Git 忽略虛擬環境
ai_app/services/3d_engines/venv_pifuhd/
venv/
.venv/

# 讓 Git 忽略大模型
ai_app/services/3d_engines/checkpoints/
models/*.onnx
# Real test samples (照片，不上 git)
tests/real_samples/*.jpg
tests/real_samples/*.jpeg
tests/real_samples/*.png
tests/real_samples/*.heic
tests/real_samples/*.heif


